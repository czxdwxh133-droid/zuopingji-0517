@inject NavigationManager Navigation

<div class="not-found">
    <div class="icon">📄</div>
    <h1>404</h1>
    <p>抱歉，您访问的页面不存在。</p>
    <button class="btn-primary" @onclick="GoHome">返回首页</button>
</div>

<style>
    .not-found { text-align: center; padding: 80px 0; }
    .icon { font-size: 48px; margin-bottom: 16px; }
    h1 { font-size: 56px; color: #94a3b8; margin-bottom: 8px; }
    p { color: #64748b; margin-bottom: 24px; font-size: 16px; }
    .btn-primary { padding: 10px 24px; background: #3b82f6; color: #fff; border: none; border-radius: 8px; font-size: 14px; cursor: pointer; }
    .btn-primary:hover { background: #2563eb; }
</style>

@code {
    private void GoHome() => Navigation.NavigateTo("/");
}
